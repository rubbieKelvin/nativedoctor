{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nativedoctor.dev/schema/request.json",
  "title": "Request resource",
  "description": "HTTP request resource. One .request.yaml file per request. Matches HttpResourceFile (camelCase).",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "Optional JSON Schema URL for this file."
    },
    "type": {
      "type": "string",
      "enum": ["http"],
      "description": "Resource type. Must be 'http' for request files."
    },
    "id": {
      "type": "string",
      "description": "Unique resource id."
    },
    "folder_id": {
      "type": ["string", "null"],
      "description": "Optional parent folder id."
    },
    "created_at": {
      "type": "integer",
      "description": "Creation timestamp (ms)."
    },
    "updated_at": {
      "type": ["integer", "null"],
      "description": "Last update timestamp (ms)."
    },
    "name": {
      "type": "string",
      "description": "Display name for the resource."
    },
    "method": {
      "type": "string",
      "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"],
      "description": "HTTP method."
    },
    "url": {
      "type": "string",
      "description": "Request URL. May contain variable placeholders e.g. {{base_url}}/api/users."
    },
    "params": {
      "type": "array",
      "description": "Query parameters.",
      "items": { "$ref": "#/$defs/KeyValuePair" }
    },
    "headers": {
      "type": "array",
      "description": "Request headers. Values may contain {{var}} placeholders.",
      "items": { "$ref": "#/$defs/KeyValuePair" }
    },
    "body": {
      "description": "Request body (e.g. JSON object for body type and content). May contain {{var}} placeholders."
    },
    "auth": {
      "description": "Auth config (e.g. { \"type\": \"none\" }, { \"type\": \"bearer\", \"token\": \"...\" })."
    },
    "pre_request_script": {
      "type": "string",
      "description": "Script run before the request (e.g. Rhai)."
    },
    "post_request_script": {
      "type": "string",
      "description": "Script run after the request (e.g. Rhai)."
    },
    "settings": {
      "$ref": "#/$defs/HttpRequestSettings",
      "description": "Request settings (redirects, timeout)."
    }
  },
  "required": ["type"],
  "$defs": {
    "HttpRequestSettings": {
      "type": "object",
      "properties": {
        "max_number_of_redirects": {
          "type": ["integer", null],
          "description": "Max redirects to follow (default 0)."
        },
        "timeout": {
          "type": ["integer", "null"],
          "description": "Request timeout in milliseconds."
        },
        "use_http2": {
          "type": ["boolean", "null"],
          "description": "Use HTTP/2 when possible (default true). Set false to force HTTP/1.1."
        }
      }
    },
    "KeyValuePair": {
      "type": "object",
      "required": ["key", "value"],
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" },
        "enabled": { "type": "boolean" },
        "description": { "type": "string" }
      }
    }
  }
}
