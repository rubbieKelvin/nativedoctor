{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nativedoctor.dev/schema/folder.json",
  "title": "Folder resource",
  "description": "Folder resource for grouping requests and sequences. One .folder.yaml file per folder. Children are not stored; tree is rebuilt from folder_id on load.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["folder"],
      "description": "Resource type. Must be 'folder' for folder files."
    },
    "id": {
      "type": "string",
      "description": "Unique resource id."
    },
    "folder_id": {
      "type": ["string", "null"],
      "description": "Optional parent folder id."
    },
    "created_at": {
      "type": "integer",
      "description": "Creation timestamp (ms)."
    },
    "updated_at": {
      "type": ["integer", "null"],
      "description": "Last update timestamp (ms)."
    },
    "name": {
      "type": "string",
      "description": "Display name for the folder."
    }
  },
  "required": ["type"]
}
